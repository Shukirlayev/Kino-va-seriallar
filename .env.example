# Environment Variables Configuration

# PostgreSQL Connection String
# Example: postgresql://postgres:password@localhost:5432/movies_db?schema=public
DATABASE_URL=""

# Telegram Bot Token (Get from @BotFather)
TELEGRAM_BOT_TOKEN=""

# Admin Telegram IDs (Comma separated IDs for users allowed to use /admin)
# Example: ADMIN_TELEGRAM_IDS="123456789,987654321"
ADMIN_TELEGRAM_IDS=""

# General App Config
# AI Studio automatically injects APP_URL at runtime
APP_URL=""
PORT="3000"
